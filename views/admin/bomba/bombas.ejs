<%- include ('./../../partials/header.ejs') %>
<%- include('./../../partials/navbar.ejs') %>
<style>

  body{
    background: #f4f6f9;
    font-family: Arial, Helvetica, sans-serif;
  }

  .container-page{
    padding: 20px;
  }

  .topo-page{
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 25px;
    flex-wrap: wrap;
    gap: 15px;
  }

  .logo{
    max-width: 180px;
  }

  .btn-nova{
    padding: 10px 18px;
    border-radius: 8px;
    font-weight: bold;
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
  }

  .card-filtro{
    background: white;
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 4px 12px rgba(0,0,0,.06);
    margin-bottom: 25px;
  }

  .titulo-filtro{
    font-size: 20px;
    font-weight: bold;
    color: #2c3e50;
    margin-bottom: 20px;
  }

  .form-label{
    font-weight: 600;
    color: #34495e;
  }

  .form-control,
  .form-select{
    border-radius: 8px;
    padding: 10px;
    border: 1px solid #dcdfe6;
  }

  .form-control:focus,
  .form-select:focus{
    border-color: #0d6efd;
    box-shadow: 0 0 0 0.15rem rgba(13,110,253,.25);
  }

  .btn-buscar{
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    font-weight: bold;
  }

  .card-tabela{
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 4px 12px rgba(0,0,0,.06);
  }

  .table{
    margin-bottom: 0;
  }

  .table thead{
    background: #f1f3f5;
  }

  .table th{
    color: #2c3e50;
    font-size: 14px;
  }

  .table td{
    vertical-align: middle;
    font-size: 14px;
  }

  .btn-abrir{
    border-radius: 8px;
    padding: 6px 14px;
    font-weight: bold;
  }

  .badge-status{
    padding: 6px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: bold;
  }

  .status-ativo{
    background: #d1f7dc;
    color: #0f5132;
  }

  .status-inativo{
    background: #f8d7da;
    color: #842029;
  }

</style>

<div class="container-page">

  <div class="topo-page">

    <img src="/images/logo2.png" class="logo">

    <p>
      Bem vindo 
    </p>

    <a 
      class="btn btn-warning btn-nova" 
      href="/portaldesantos/admin/bomba/new-bomba"
    >
      + Nova Bomba
    </a>

  </div>

  <!-- FILTRO -->

  <div class="card-filtro">

    <div class="titulo-filtro">
      Filtro de Bombas
    </div>

    <form method="GET" action="/bombas/filtro">

      <div class="row g-3 align-items-end">

        <div class="col-md-4">

          <label class="form-label">
            Empresa
          </label>

          <select 
            name="empresa" 
            class="form-select"
          >

            <option value="">
              Todas Empresas
            </option>

            <option value="SANTOUR">
              SANTOUR
            </option>

            <option value="GAIVOTA">
              GAIVOTA
            </option>

            <option value="LUNAR">
              LUNAR
            </option>

            <option value="MFR">
              MFR
            </option>

          </select>

        </div>

        <div class="col-md-4">

          <label class="form-label">
            Status
          </label>

          <select 
            name="status" 
            class="form-select"
          >

            <option value="">
              Todos
            </option>

            <option value="1">
              Ativa
            </option>

            <option value="0">
              Inativa
            </option>

          </select>

        </div>

        <div class="col-md-4">

          <button 
            type="submit" 
            class="btn btn-primary btn-buscar"
          >
            Buscar
          </button>

        </div>

      </div>

    </form>

  </div>

  <!-- TABELA -->

  <div class="card-tabela">

    <table class="table table-hover align-middle">

      <thead>

        <tr>
          <th>ID</th>
          <th>Número</th>
          <th>Nome</th>
          <th>Fabricante</th>
          <th>Empresa</th>
          <th>Nº Série</th>
          <th>Modelo</th>
          <th>Status</th>
          <th>Ação</th>
        </tr>

      </thead>

      <tbody>

        <% bombas.forEach(bomba => { %>

          <tr>

            <td>
              <b>#<%= bomba.id %></b>
            </td>

            <td>
              <%= bomba.numero %>
            </td>

            <td>
              <%= bomba.nome %>
            </td>

            <td>
              <%= bomba.fabricante %>
            </td>

            <td>
              <%= bomba.empresa %>
            </td>

            <td>
              <%= bomba.numero_serie %>
            </td>

            <td>
              <%= bomba.modelo %>
            </td>

            <td>

              <% if(bomba.is_ativo == 1){ %>

                <span class="badge-status status-ativo">
                  ATIVA
                </span>

              <% } else { %>

                <span class="badge-status status-inativo">
                  INATIVA
                </span>

              <% } %>

            </td>

            <td>

              <a 
                class="btn btn-success btn-sm btn-abrir"
                href="/portaldesantos/admin/bomba/bomba/<%= bomba.id %>"
              >
                Abrir
              </a>
               <a 
                class="btn btn-warning btn-sm btn-abrir"
                href="/portaldesantos/admin/edit/bomba/<%= bomba.id %>"
              >
                Editar
              </a>

              <form method="POST" action="/portaldesantos/admin/bomba/delete" onsubmit="confirmarDelecao(event,this)" style="display: inline;">
                    <input type="hidden" id="idBomba" name="idBomba" value="<%= bomba.id %>">
                    <input type="hidden" id="nome_empresa" name="nome_empresa" value="<%= bomba.empresa %>">
                    <button class="btn btn-danger">Excluir</button>
              </form>

            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

  </div>

</div>
<script>
   function confirmarDelecao(event, form) {
        const confirmado = confirm("Deseja realmente excluir esta Bomba?");
        if (!confirmado) {
        event.preventDefault();
        }
    }
</script>
<%- include('./../../partials/footer.ejs') %>